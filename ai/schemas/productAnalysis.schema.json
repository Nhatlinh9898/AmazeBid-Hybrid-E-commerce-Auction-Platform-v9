{
  "$id": "productAnalysis.schema.json",
  "type": "object",
  "required": ["name", "category", "attributes", "confidence"],
  "properties": {
    "name": { "type": "string" },
    "category": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "attributes": {
      "type": "object",
      "properties": {
        "color": { "type": "string" },
        "size": { "type": "string" },
        "material": { "type": "string" }
      },
      "additionalProperties": true
    },
    "canonical_version": { "type": "string" }
  }
}
