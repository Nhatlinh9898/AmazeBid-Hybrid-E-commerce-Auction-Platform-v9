rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Primitives & Helpers
    // ===============================================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email.matches('(?i)Nhatlinhckm2016@gmail.com') ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // ===============================================================
    // Knowledge Base Entities
    // ===============================================================

    function isValidKnowledgeItem(data) {
      // Allow flexible size to avoid breaking on minor schema changes, but ensure core fields
      return data.keys().hasAll(['type', 'title', 'content', 'createdAt', 'createdBy', 'creatorName', 'tags']) &&
             data.type in ['TEXT', 'IMAGE', 'VIDEO', 'SPEC', 'INSTRUCTION'] &&
             data.title is string && data.title.size() <= 256 &&
             data.content is string && data.content.size() <= 1000000 &&
             data.createdAt is string &&
             data.createdBy == request.auth.uid &&
             data.creatorName is string &&
             data.tags is list && data.tags.size() <= 100;
    }

    match /knowledge_base/{itemId} {
      // allow read is shorthand for get + list
      allow read: if isSignedIn();

      allow create: if isVerified() && 
                      isValidKnowledgeItem(incoming()) &&
                      incoming().createdBy == request.auth.uid;

      allow update: if isVerified() && 
                      isValidKnowledgeItem(incoming()) &&
                      (existing().createdBy == request.auth.uid || isAdmin()) &&
                      incoming().createdBy == existing().createdBy &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['type', 'title', 'content', 'tags', 'creatorName', 'isPublic']);

      allow delete: if isVerified() && (existing().createdBy == request.auth.uid || isAdmin());
    }

    // ===============================================================
    // User Profiles
    // ===============================================================

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isVerified() && (request.auth.uid == userId || isAdmin());
    }

    // ===============================================================
    // Connectivity & Admin Helpers
    // ===============================================================

    match /test/connection {
      allow read: if isSignedIn();
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Managed via console
    }
  }
}
